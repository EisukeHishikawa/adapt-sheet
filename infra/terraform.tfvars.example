# infra/terraform.tfvars として複製し、環境に合わせて調整する（このexampleはコミット、実tfvarsは.gitignore）。
# APIキー等の秘密情報はここには書かない（Parameter Storeへ別途投入する。ADR-017）。

aws_region  = "ap-northeast-1"
project     = "adapt-sheet"
environment = "prod"

# ECR Privateへpush済みのbackendイメージタグ（CIが更新する運用を想定）。
image_tag = "latest"

# Lambda（PDF処理に余裕を持たせる）。timeoutはAPI Gateway REST APIの統合タイムアウト上限に揃える。
lambda_memory_size = 4096
lambda_timeout     = 29

# docling-service / pdf2htmlex-service（ADR-026）。ECR Privateへpush済みのイメージタグ（CIが更新する運用を想定）。
docling_image_tag    = "latest"
pdf2htmlex_image_tag = "latest"

docling_lambda_memory_size = 6144
docling_lambda_timeout     = 60
# MLモデルはイメージへ焼き込むが、torch/HuggingFaceの実行時キャッシュは/tmpへ書くため拡張する。
docling_lambda_ephemeral_storage_size = 2048

pdf2htmlex_lambda_memory_size = 2048
pdf2htmlex_lambda_timeout     = 60

# 本番は実AIを叩く。
use_mock_ai = "false"

# API Gatewayステージ全体（全メソッド合算）のスロットリング（IP単位ではない。ADR-027）。
api_throttle_rate_limit  = 50
api_throttle_burst_limit = 100

# ログ・可観測性（ADR-030）。保持期間はLambda/API Gateway/CloudFrontのログへ共通で適用される。
log_retention_in_days            = 30
enable_xray                      = true
enable_cloudfront_access_logging = true

# CloudWatchアラームの通知先。空のままならSNSトピックだけを作り、購読は作らない。
# 設定した場合、AWSから届く購読確認メールのリンクを踏むまで通知は配信されない。
alarm_email = ""
