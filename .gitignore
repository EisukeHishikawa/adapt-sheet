# OS
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/

# フロントの型生成（npm run generate-types）の入力となる生成物。
# backend/scripts/export_openapi.py で都度生成するためコミット対象外とする。
backend/openapi.json

# Node
node_modules/
dist/
.vite/

# Env
.env
.env.local

# Terraform（フェーズ4 ステップ25）。state・ローカルキャッシュ・実tfvars（秘密や環境依存値を含む）は
# コミットしない。モジュール定義とexampleのみを管理対象にする。
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
crash.log

# Editor / local notes
# .claude/CLAUDE.md（個人メモ）・settings.local.json・scheduled_tasks.lock等は非公開のまま維持しつつ、
# チームで共有すべき.claude/skills/配下のみ例外的にGit管理対象にする。
.claude/*
!.claude/skills/
docker-compose.override.yml
